  <div id="header-right">
    <a href="mailto:hello@joeplab.com" id="header-talk-btn">
      <span>Let's talk</span>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.343 8h11.314m0 0L8.673 3.016M13.657 8l-4.984 4.984"/>
      </svg>
    </a>
    <button id="header-menu-btn" aria-label="Menu">
      <span>Menu</span>
      <div style="display:flex;gap:4px;margin-left:6px">
        <span class="menu-dot"></span>
        <span class="menu-dot"></span>
      </div>
    </button>
  </div>
</header>

